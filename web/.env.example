# Get these with `npx configure setup` or from https://configure.dev

# Secret key — server-side only. Never ship this to the browser.
CONFIGURE_API_KEY=sk_...

# Publishable key — safe in the browser. Used only to build the sign-in link.
CONFIGURE_PUBLISHABLE_KEY=pk_...

# Your agent handle in Configure.
CONFIGURE_AGENT=your-agent

# Where this app runs. Configure redirects back to BASE_URL/callback after sign-in.
BASE_URL=http://localhost:4000
PORT=4000
