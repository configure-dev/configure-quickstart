# Configure — get these with `npx configure setup` or from https://configure.dev
CONFIGURE_API_KEY=sk_...
CONFIGURE_PUBLISHABLE_KEY=pk_...
CONFIGURE_AGENT=your-agent

# Photon / Spectrum — get these from https://app.photon.codes
PHOTON_PROJECT_ID=
PHOTON_PROJECT_SECRET=

# Your agent's iMessage line (E.164). Lets the sign-in page offer a "text back" button.
AGENT_PHONE_NUMBER=+1...

# Claude — the agent's brain. https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
